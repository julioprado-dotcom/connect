# Z.ai Sandbox / Runtime
.zscripts/
worklog.md
# download/ — ignore everything except productos/ and docs (generated PDFs go to GitHub)
download/*
!download/productos/
download/productos/*
!download/productos/semana-*/
!download/MANIFIESTO-INSTALACION-VPS.md
node_modules/

# Database — custom.db is NOT tracked (VPS is source of truth)
# The VPS database lives only on the server, never in git.
# git reset --hard will NOT overwrite it.
prisma/db/custom.db
prisma/db/custom.db.*

# Legacy/conflicting databases — DO NOT track
backups/*.db
prisma/dev.db
prisma/db/custom-empty-backup.db
prisma/db/*.bak

# Sensitive / session files
HANDOFF.md
worklog_backup.md
worklog-session2.md
agent-ctx/

# Environment
.env
.env.local
upload/.env*

# Next.js
.next/
out/
next-env.d.ts

# Prisma
prisma/migrations/
.prisma-schema-hash
# prisma/generated-client/ is TRACKED — contains pre-generated Prisma Client for VPS deploy
# (eliminates prisma generate from deploy pipeline)

# Database
db/
*.db-journal
*.db-wal
nohup.out
start-*.sh
server.pid
tmp-query.cjs
connect/

# ZAI SDK config (contains API key — never commit this)
.z-ai-config
.z-ai-config.*
!/.z-ai-config.example

# Z.ai skills (managed externally)
skills/

# Build artifacts
tsconfig.tsbuildinfo
package-lock.json

# Temp data files
search*.json
social_search*.json
suplentes_detalle.json

# Scraping / parse scripts (one-off utilities)
parse_*.py
build_final_json.py

# Misc
.DS_Store
*.log
tmp/
CLAUDE.md
AGENTS.md
*.disabled
_scripts_disabled/
scripts/logs/
examples/
decodeX-bolivia/
mini-services/

# Temporary data files from web scraping
data/*.pdf
data/*.xlsx
data/*_electos.json
data/*_search*.json
data/diputados_*.json
data/unitel_*.json
data/oep_*.json
data/elpais_*.json
data/erbol_*.json
data/boliviaverifica_*.json
data/electos_*.json
data/electos_2025_text.txt
