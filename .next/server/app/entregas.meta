{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/entregas/layout,_N_T_/entregas/page,_N_T_/entregas"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/entregas/__PAGE__",
    "/entregas",
    "/_index",
    "/_head"
  ]
}